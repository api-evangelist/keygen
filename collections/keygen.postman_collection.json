              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Update a license",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/vnd.api+json" },
              { "key": "Accept", "value": "application/vnd.api+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": { \"type\": \"licenses\", \"attributes\": {} }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Delete a license",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Validate a license (by ID)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/vnd.api+json" },
              { "key": "Accept", "value": "application/vnd.api+json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses/:id/actions/validate",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", ":id", "actions", "validate"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Validate a license (by key)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/vnd.api+json" },
              { "key": "Accept", "value": "application/vnd.api+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meta\": { \"key\": \"{{licenseKey}}\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses/actions/validate-key",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", "actions", "validate-key"]
            },
            "description": "Validate a license using its key with no prior authentication."
          }
        },
        {
          "name": "Check-out a license",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses/:id/actions/check-out",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", ":id", "actions", "check-out"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Check-in a license",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses/:id/actions/check-in",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses", ":id", "actions", "check-in"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        }
      ]
    },
