{
  "info": {
    "name": "Keygen API",
    "description": "Keygen software licensing, entitlements, and distribution API. JSON:API over application/vnd.api+json, scoped to /v1/accounts/{{account}}. Authenticate with a Bearer token (admin/environment/product/user/license) or a license key.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.keygen.sh"
    },
    {
      "key": "account",
      "value": "your-account-id"
    },
    {
      "key": "bearerToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Tokens",
      "item": [
        {
          "name": "Generate a token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/vnd.api+json" },
              { "key": "Accept", "value": "application/vnd.api+json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/tokens",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "tokens"]
            },
            "description": "Generate a bearer token via HTTP Basic (user token) or a license key (license token)."
          }
        },
        {
          "name": "List all tokens",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/tokens",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "tokens"]
            }
          }
        },
        {
          "name": "Retrieve a token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/tokens/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "tokens", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Regenerate a token",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/tokens/:id/actions/regenerate",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "tokens", ":id", "actions", "regenerate"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Revoke a token",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/tokens/:id/actions/revoke",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "tokens", ":id", "actions", "revoke"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Licenses",
      "item": [
        {
          "name": "Create a license",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/vnd.api+json" },
              { "key": "Accept", "value": "application/vnd.api+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"type\": \"licenses\",\n    \"relationships\": {\n      \"policy\": { \"data\": { \"type\": \"policies\", \"id\": \"{{policyId}}\" } }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/{{account}}/licenses",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "accounts", "{{account}}", "licenses"]
            }
          }
        },
        {
          "name": "List all licenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/vnd.api+json" }],
